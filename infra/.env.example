# FixMyPlant — Environment Variables
# Copy this file to the project root as .env and fill in real values.

ENVIRONMENT=local

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# Ollama (Spec 02 — not needed yet)
# OLLAMA_BASE_URL=http://localhost:11434

# Vision OCR (Spec 03 — not needed yet)
# VISION_API_KEY=your-api-key-here
# VISION_PROVIDER=anthropic
